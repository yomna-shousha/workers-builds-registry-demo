# Authenticate to your npm registry using the NPM_TOKEN build secret.
# Set NPM_TOKEN in Workers Builds: Settings > Build > Build variables and secrets.
#
# Replace "registry.your-company.com" with your actual registry URL.
# Replace "@yourscope" with your actual npm scope.
#
# Example for GitHub Packages:
#   //npm.pkg.github.com/:_authToken=${NPM_TOKEN}
#   @your-org:registry=https://npm.pkg.github.com
#
# Example for Artifactory:
#   //your-company.jfrog.io/artifactory/api/npm/npm-local/:_authToken=${NPM_TOKEN}
#   @yourscope:registry=https://your-company.jfrog.io/artifactory/api/npm/npm-local/

//registry.your-company.com/:_authToken=${NPM_TOKEN}
@yourscope:registry=https://registry.your-company.com/
