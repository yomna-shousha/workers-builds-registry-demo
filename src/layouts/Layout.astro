---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: #0a0a0a;
        color: #e5e5e5;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }
      .container {
        max-width: 640px;
        width: 100%;
      }
      h1 {
        font-size: 2rem;
        margin-bottom: 1rem;
        color: #f97316;
      }
      p {
        line-height: 1.6;
        margin-bottom: 1rem;
        color: #a3a3a3;
      }
      code {
        background: #1a1a1a;
        padding: 0.15em 0.4em;
        border-radius: 4px;
        font-size: 0.9em;
        color: #f97316;
      }
      .badge {
        display: inline-block;
        background: #f97316;
        color: #0a0a0a;
        padding: 0.25em 0.75em;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-bottom: 1rem;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <slot />
    </div>
  </body>
</html>
